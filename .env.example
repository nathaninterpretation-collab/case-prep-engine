# Server port
PORT=3200

# Optional: server-wide Anthropic API key (fallback if user has no key)
ANTHROPIC_API_KEY=

# Required: JWT signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Required: encryption key for stored API keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=
